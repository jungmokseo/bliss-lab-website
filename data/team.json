  "pi": {
    "id": "seo-jungmok",
    "initials": "JS",
    "nameKr": "서정목",
    "nameEn": "Jungmok Seo",
    "roleKr": "부교수 · 연구책임자",
    "roleEn": "Associate Professor · Principal Investigator",
    "bioKr": "연세대학교 전기전자공학과에서 BLISS Lab을 이끌고 있으며, 소프트 바이오 전극 소재, 바이오 인터페이스 공학, 이식형 센서 신뢰성, 신축성 회로 및 IC 패키징을 연구합니다. 생체와 전자소자 사이의 물리적·전기적 경계를 허무는 차세대 바이오일렉트로닉스 시스템을 개발합니다.",
    "bioEn": "Prof. Seo leads the BLISS Lab in the School of Electrical and Electronic Engineering at Yonsei University, driving research across soft bioelectrode materials, bio-interface engineering, implantable sensor reliability, and stretchable circuits with IC packaging. His work breaks down the physical and electrical barriers between living tissue and electronic systems, creating next-generation bioelectronics that seamlessly bridge biology and EE.",
    "education": [
      "Ph.D., School of Electrical and Electronic Engineering, Yonsei University (2008–2014)",
      "B.S., School of Electrical and Electronic Engineering, Yonsei University (2004–2008)"
    ],
    "career": [
